{
  "openapi": "3.1.0",
  "info": {
    "title": "Bartender API",
    "version": "1",
    "description": "API for managing sandboxes and snapshots."
  },
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Sandbox": {
        "type": "object",
        "required": [
          "_type",
          "id",
          "status",
          "ephemeral",
          "cluster_name",
          "current_version_number",
          "next_version_number",
          "millicpu",
          "gpu",
          "memory_bytes",
          "disk_bytes",
          "version_count",
          "agent_version",
          "agent_type",
          "agent_token",
          "agent_url",
          "created_at",
          "start_scheduled_at",
          "start_type",
          "started_at",
          "stop_scheduled_at",
          "scheduled_stop_type",
          "stopped_at",
          "stop_reason",
          "specs_updated_at",
          "recovery_status",
          "recovery_scheduled_at",
          "recovery_finished_at",
          "updated_at"
        ],
        "properties": {
          "_type": {
            "type": "string",
            "enum": [
              "sandbox"
            ]
          },
          "id": {
            "type": "string",
            "description": "Short identifier (6\u20138 characters)."
          },
          "status": {
            "type": "string",
            "enum": [
              "created",
              "starting",
              "running",
              "stopping",
              "stopped"
            ]
          },
          "ephemeral": {
            "type": "boolean"
          },
          "cluster_name": {
            "type": "string"
          },
          "current_version_number": {
            "type": "integer"
          },
          "next_version_number": {
            "type": "integer"
          },
          "millicpu": {
            "type": "integer",
            "description": "CPU allocation in millicpu."
          },
          "gpu": {
            "type": "integer"
          },
          "memory_bytes": {
            "type": "integer"
          },
          "disk_bytes": {
            "type": "integer"
          },
          "version_count": {
            "type": "integer"
          },
          "agent_version": {
            "type": "string"
          },
          "agent_type": {
            "type": "string"
          },
          "agent_token": {
            "type": "string"
          },
          "agent_url": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "start_scheduled_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "start_type": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "resume",
              "cold_start",
              null
            ]
          },
          "started_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "stop_scheduled_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "scheduled_stop_type": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "shutdown",
              "hibernate",
              null
            ]
          },
          "stopped_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "stop_reason": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "start_failed",
              "shutdown",
              "hibernated",
              "crashed",
              "oom_killed",
              "evicted",
              "node_lost",
              "cluster_lost",
              null
            ]
          },
          "specs_updated_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "recovery_status": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "pending",
              "recovered",
              "canceled",
              "unrecoverable",
              null
            ]
          },
          "recovery_scheduled_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "recovery_finished_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Snapshot": {
        "type": "object",
        "required": [
          "_type",
          "id",
          "byte_size",
          "protected",
          "optimized",
          "includes_memory_snapshot",
          "created_at",
          "optimized_at",
          "updated_at"
        ],
        "properties": {
          "_type": {
            "type": "string",
            "enum": [
              "snapshot"
            ]
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "byte_size": {
            "type": "integer"
          },
          "protected": {
            "type": "boolean"
          },
          "optimized": {
            "type": "boolean"
          },
          "includes_memory_snapshot": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "optimized_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SandboxVersion": {
        "type": "object",
        "required": [
          "_type",
          "id",
          "sandbox_id",
          "number",
          "snapshot_id",
          "created_at"
        ],
        "properties": {
          "_type": {
            "type": "string",
            "enum": [
              "sandbox_version"
            ]
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "sandbox_id": {
            "type": "string",
            "description": "Short identifier (6\u20138 characters)."
          },
          "number": {
            "type": "integer"
          },
          "snapshot_id": {
            "type": "string",
            "format": "uuid"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "_type",
          "code",
          "message"
        ],
        "properties": {
          "_type": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "parameter": {
                  "type": "string"
                },
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "details": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "paths": {
    "/sandboxes": {
      "get": {
        "operationId": "listSandboxes",
        "summary": "List sandboxes",
        "parameters": [
          {
            "name": "namespace",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of sandboxes.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Sandbox"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      },
      "post": {
        "operationId": "createSandbox",
        "summary": "Create a sandbox",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "millicpu",
                  "memory_bytes",
                  "disk_bytes"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Sandbox ID (6\u20138 characters). Generated if not provided.",
                    "minLength": 6,
                    "maxLength": 8
                  },
                  "snapshot_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "ID of the snapshot to use. One of snapshot_id or snapshot_alias is required.\n"
                  },
                  "snapshot_alias": {
                    "type": "string",
                    "description": "Alias of the snapshot to use. One of snapshot_id or snapshot_alias is required.\n"
                  },
                  "ephemeral": {
                    "type": "boolean"
                  },
                  "millicpu": {
                    "type": "integer",
                    "description": "CPU allocation in millicpu. Must be > 0 and a multiple of 250.",
                    "minimum": 250,
                    "multipleOf": 250
                  },
                  "memory_bytes": {
                    "type": "integer",
                    "description": "Memory allocation in bytes. Must be > 0.",
                    "minimum": 1
                  },
                  "disk_bytes": {
                    "type": "integer",
                    "description": "Disk allocation in bytes. Must be > 0.",
                    "minimum": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Sandbox created.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Sandbox"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/sandboxes/batch": {
      "get": {
        "operationId": "batchGetSandboxes",
        "summary": "Batch get sandboxes by IDs",
        "parameters": [
          {
            "name": "ids[]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "maxItems": 100
            },
            "style": "form",
            "explode": true,
            "description": "List of sandbox IDs. Maximum 100, no duplicates."
          }
        ],
        "responses": {
          "200": {
            "description": "List of sandboxes (preserves request order; missing IDs are omitted).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Sandbox"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/sandboxes/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "description": "Sandbox ID (6\u20138 characters)."
          }
        }
      ],
      "get": {
        "operationId": "getSandbox",
        "summary": "Get a sandbox by ID",
        "responses": {
          "200": {
            "description": "Sandbox.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Sandbox"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "operationId": "deleteSandbox",
        "summary": "Delete a sandbox",
        "responses": {
          "204": {
            "description": "Sandbox deleted."
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/sandboxes/{id}/start": {
      "post": {
        "operationId": "startSandbox",
        "summary": "Start a sandbox",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Sandbox ID (6\u20138 characters)."
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "version_number": {
                    "type": "integer",
                    "description": "Version to start. Uses the current version if not provided.",
                    "minimum": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sandbox with updated status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Sandbox"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/sandboxes/{id}/stop": {
      "post": {
        "operationId": "stopSandbox",
        "summary": "Stop a sandbox",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Sandbox ID (6\u20138 characters)."
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "stop_type": {
                    "type": "string",
                    "enum": [
                      "shutdown",
                      "hibernate"
                    ],
                    "default": "shutdown",
                    "description": "How to stop the sandbox."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sandbox with updated status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Sandbox"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/sandboxes/{id}/wait": {
      "post": {
        "operationId": "waitSandbox",
        "summary": "Wait for a sandbox to reach a terminal status",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Sandbox ID (6\u20138 characters)."
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sandbox at terminal status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Sandbox"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/sandboxes/{sandbox_id}/versions/current": {
      "get": {
        "operationId": "getCurrentSandboxVersion",
        "summary": "Get the current version of a sandbox",
        "parameters": [
          {
            "name": "sandbox_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Sandbox ID (6\u20138 characters)."
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sandbox version.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SandboxVersion"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/sandboxes/{sandbox_id}/versions/{number}": {
      "get": {
        "operationId": "getSandboxVersionByNumber",
        "summary": "Get a sandbox version by sandbox ID and version number",
        "parameters": [
          {
            "name": "sandbox_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Sandbox ID (6\u20138 characters)."
            }
          },
          {
            "name": "number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sandbox version.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SandboxVersion"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/sandbox-versions/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "operationId": "getSandboxVersion",
        "summary": "Get a sandbox version by ID",
        "responses": {
          "200": {
            "description": "Sandbox version.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SandboxVersion"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "operationId": "deleteSandboxVersion",
        "summary": "Delete a sandbox version by ID",
        "responses": {
          "204": {
            "description": "Sandbox version deleted."
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/snapshots": {
      "get": {
        "operationId": "listSnapshots",
        "summary": "List snapshots",
        "parameters": [
          {
            "name": "namespace",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of snapshots.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Snapshot"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      },
      "put": {
        "operationId": "putSnapshot",
        "summary": "Create or retrieve a snapshot for a container image",
        "description": "Idempotent. If a snapshot already exists for the given image it is returned instead of creating a new one.\n",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "image"
                ],
                "properties": {
                  "image": {
                    "type": "object",
                    "required": [
                      "name"
                    ],
                    "properties": {
                      "registry": {
                        "type": "string"
                      },
                      "repository": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "tag": {
                        "type": "string"
                      },
                      "architecture": {
                        "type": "string",
                        "enum": [
                          "amd64",
                          "arm64"
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Snapshot.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Snapshot"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/snapshots/batch": {
      "get": {
        "operationId": "batchGetSnapshots",
        "summary": "Batch get snapshots by IDs",
        "parameters": [
          {
            "name": "ids[]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uuid"
              },
              "maxItems": 100
            },
            "style": "form",
            "explode": true,
            "description": "List of snapshot UUIDs. Maximum 100, no duplicates."
          }
        ],
        "responses": {
          "200": {
            "description": "List of snapshots (preserves request order; missing IDs are omitted).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Snapshot"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/snapshots/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "operationId": "getSnapshot",
        "summary": "Get a snapshot by ID",
        "responses": {
          "200": {
            "description": "Snapshot.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Snapshot"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "operationId": "deleteSnapshot",
        "summary": "Delete a snapshot",
        "responses": {
          "204": {
            "description": "Snapshot deleted."
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/snapshots/{snapshot_id}/aliases": {
      "post": {
        "operationId": "aliasSnapshot",
        "summary": "Assign an alias to a snapshot",
        "parameters": [
          {
            "name": "snapshot_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "alias"
                ],
                "properties": {
                  "alias": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Alias assigned."
          },
