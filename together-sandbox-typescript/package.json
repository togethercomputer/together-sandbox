{
  "name": "@together-sandbox/sdk",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "generate": "openapi-ts -i ../api-openapi.json -o src/api-clients/api -c @hey-api/client-fetch && openapi-ts -i ../sandbox-openapi.json -o src/api-clients/sandbox -c @hey-api/client-fetch",
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.84.4",
    "@types/node": "^22.15.30",
    "typescript": "^5.7.2"
  }
}
