{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "packages": {
    ".": {
      "release-type": "node",
      "extra-files": [
        {
          "type": "json",
          "path": "together-sandbox-typescript/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "together-sandbox-cli/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "together-sandbox-python/pyproject.toml",
          "jsonpath": "$.project.version"
        }
      ]
    }
  }
}
